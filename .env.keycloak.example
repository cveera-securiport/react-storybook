# Copy to `.env.keycloak` (gitignored) and adjust for your machine.
# Used by: docker compose --env-file .env.keycloak -f docker-compose.keycloak.yml up -d
#
# Dev-only: use strong passwords if your Keycloak port is reachable on a network.

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-in-dev-only
