{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "paths": {
      "@ibc/ui": ["../../libs/shared/ui/src/index.ts"],
      "@ibc/ui/*": ["../../libs/shared/ui/src/*"],
      "@ibc/tokens": ["../../libs/shared/tokens/src/index.ts"],
      "@ibc/tokens/*": ["../../libs/shared/tokens/src/*"],
      "@ibc/schema-forms": ["../../libs/shared/schema-forms/src/index.ts"],
      "@ibc/schema-forms/*": ["../../libs/shared/schema-forms/src/*"]
    }
  },
  "include": ["src", "../../libs/shared/*/src"],
  "references": [
    { "path": "../../libs/shared/ui" },
    { "path": "../../libs/shared/tokens" }
  ]
}
